{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend",
      "type": "shell",
      "command": "source venv/bin/activate && uvicorn backend.server:app --port 8001 --reload",
      "windows": { "command": "venv\\Scripts\\activate && uvicorn backend.server:app --port 8001 --reload" },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Frontend",
      "type": "shell",
      "command": "cd mobile && npm run dev",
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Start All",
      "dependsOn": ["Backend", "Frontend"],
      "dependsOrder": "parallel",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    }
  ]
}
