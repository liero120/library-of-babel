# LLM Backend: "api" or "browser"
# api = Direct Claude API (needs ANTHROPIC_API_KEY)
# browser = Headless Playwright → M365 Copilot Chat (no API key needed)
LLM_BACKEND=browser

# For API mode (leave blank to use Claude Code CLI fallback)
ANTHROPIC_API_KEY=

# For browser mode — M365 Copilot Chat
COPILOT_URL=https://m365.cloud.microsoft/chat/
# Selectors auto-detected, but can override:
# COPILOT_INPUT_SELECTOR=[role="textbox"][contenteditable="true"]
# COPILOT_RESPONSE_SELECTOR=.fai-CopilotMessage__content
