[Unit]
Description=Library of Babel (FastAPI Critical Reading Partner)
After=network.target

[Service]
Type=simple
User=alfonso
WorkingDirectory=/home/alfonso/library-of-babel
ExecStart=/home/alfonso/library-of-babel/venv/bin/uvicorn backend.server:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5
EnvironmentFile=/home/alfonso/library-of-babel/.env

[Install]
WantedBy=multi-user.target
